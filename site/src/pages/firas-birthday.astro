---
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;

const audioSrc = `${baseUrl}assets/firas-birthday/firas-birthday.mp3`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Firas Birthday</title>
		<meta name="description" content="A tiny surprise for Firas." />

		<style>
			:root {
				color-scheme: dark;
			}

			html,
			body {
				width: 100%;
				height: 100%;
				overflow: hidden;
			}

		body {
			margin: 0;
			display: grid;
			place-items: center;
			font-size: 24px;
			font-weight: 600;
			font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
			-webkit-font-smoothing: antialiased;
			color: #444;
			background:
				radial-gradient(1200px 700px at 15% 20%, rgba(255, 209, 255, 0.35), transparent 55%),
				radial-gradient(1000px 600px at 85% 10%, rgba(189, 224, 254, 0.3), transparent 50%),
				radial-gradient(900px 700px at 75% 85%, rgba(202, 255, 191, 0.3), transparent 55%),
				radial-gradient(800px 700px at 25% 85%, rgba(255, 243, 176, 0.25), transparent 55%),
				linear-gradient(135deg, #0a0014 0%, #140024 40%, #05010a 100%);
			background-size: 200% 200%;
			animation: glow-shift 12s ease-in-out infinite;
			perspective: 1000px;
		}

		canvas {
			position: fixed;
			inset: 0;
			z-index: 1;
			image-rendering: auto;
			image-rendering: crisp-edges;
			image-rendering: pixelated;
		}

		.moving-text {
			position: fixed;
			inset: 0;
			overflow: hidden;
			pointer-events: none;
			z-index: 0;
		}

		.moving-text span {
			position: absolute;
			white-space: nowrap;
			font-size: clamp(18px, 3vw, 36px);
			font-weight: 600;
			color: rgba(255, 255, 255, 0.28);
			letter-spacing: 0.04em;
			mix-blend-mode: screen;
			filter: drop-shadow(0 6px 20px rgba(0, 0, 0, 0.35));
		}

		.moving-text span.fast {
			font-size: clamp(16px, 2.2vw, 28px);
			color: rgba(255, 255, 255, 0.45);
			letter-spacing: 0.12em;
			text-transform: uppercase;
		}

		@keyframes drift-right {
			0% {
				transform: translateX(-120%) translateY(-10px) rotate(-2deg);
				opacity: 0;
			}
			10% {
				opacity: 0.6;
			}
			90% {
				opacity: 0.6;
			}
			100% {
				transform: translateX(120%) translateY(10px) rotate(2deg);
				opacity: 0;
			}
		}

		@keyframes drift-left {
			0% {
				transform: translateX(120%) translateY(10px) rotate(2deg);
				opacity: 0;
			}
			10% {
				opacity: 0.6;
			}
			90% {
				opacity: 0.6;
			}
			100% {
				transform: translateX(-120%) translateY(-10px) rotate(-2deg);
				opacity: 0;
			}
		}

		button {
			font: inherit;
			appearance: none;
			-webkit-appearance: none;
			outline: none;
			padding: 32px 64px;
			font-size: 96px;
			color: #000;
			text-shadow: 0 1px 2px hsla(0, 0%, 100%, 0.15);
			background-color: #ad68d9;
				background-image: linear-gradient(#ad68d9, #a960d7);
				box-shadow: inset 0 0 2px hsla(0, 0%, 100%, 0.15);
				border: none;
				border-radius: 8px;
				cursor: pointer;
			transition: all 0.15s ease-out;
			z-index: 2;
		}

			button:hover {
				transform: scale(1.05);
				background-image: linear-gradient(#c391e3, #bf89e1);
			}

			button:active {
				transform: scale(0.95);
				opacity: 0.5;
			}

			audio {
				position: absolute;
				width: 0;
				height: 0;
				visibility: hidden;
			}

		@keyframes Cue-In {
				0% {
					opacity: 0;
					transform: scale(0.1) rotateX(45deg);
				}

				100% {
					transform: scale(1) rotateX(0);
				}
		}

		.cue-in {
			animation: Cue-In 2s ease-in-out;
		}

		@keyframes glow-shift {
			0% {
				background-position: 0% 50%;
			}
			50% {
				background-position: 100% 50%;
			}
			100% {
				background-position: 0% 50%;
			}
		}
		</style>
	</head>
	<body data-base-url={baseUrl}>
		<div class="moving-text" aria-hidden="true">
			<span style="top: 12%; animation: drift-right 18s linear infinite;">
				Telet atyab chab men ba3d el chocoprince
			</span>
			<span class="fast" style="top: 20%; animation: drift-right 8s linear infinite 0.5s;">
				Firas Khoury
			</span>
			<span style="top: 28%; animation: drift-left 22s linear infinite 1s;">
				Telet atyab chab men ba3d el chocoprince
			</span>
			<span class="fast" style="top: 36%; animation: drift-left 9s linear infinite 1.2s;">
				Firas Khoury
			</span>
			<span style="top: 45%; animation: drift-right 20s linear infinite 2.5s;">
				Telet atyab chab men ba3d el chocoprince
			</span>
			<span class="fast" style="top: 54%; animation: drift-right 7.5s linear infinite 1.8s;">
				Firas Khoury
			</span>
			<span style="top: 62%; animation: drift-left 24s linear infinite 3.5s;">
				Telet atyab chab men ba3d el chocoprince
			</span>
			<span class="fast" style="top: 70%; animation: drift-left 8.5s linear infinite 0.8s;">
				Firas Khoury
			</span>
			<span style="top: 78%; animation: drift-right 21s linear infinite 1.5s;">
				Telet atyab chab men ba3d el chocoprince
			</span>
			<span class="fast" style="top: 86%; animation: drift-right 7s linear infinite 2.2s;">
				Firas Khoury
			</span>
		</div>

		<audio id="party-audio" src={audioSrc} preload="auto" loop></audio>

		<noscript>
			<p>Enable JavaScript to see the surprise.</p>
		</noscript>

		<script>
			const BASE_URL = document.body?.dataset?.baseUrl || "/";

			class Sprite {
				constructor(image, frames) {
					const width = image.width;
					const height = image.height;

					const canvas = document.createElement("canvas");
					canvas.width = width;
					canvas.height = height;

					const context = canvas.getContext("2d");
					context.drawImage(image, 0, 0);

					this.canvas = canvas;
					this.context = context;
					this.frames = frames;
				}

				drawFrame(ctx, frame, dx, dy, targetWidth, targetHeight) {
					const { x, y, width, height } = this.frames[frame];

					dx |= 0;
					dy |= 0;
					targetWidth |= width;
					targetHeight |= height;

					ctx.drawImage(
						this.canvas,
						x,
						y,
						width,
						height,
						dx,
						dy,
						targetWidth,
						targetHeight
					);
				}

				static GeometryHorizontalLinear(width, height, count) {
					const frames = [];
					for (let idx = 0; idx < count; idx += 1) {
						frames.push({ x: width * idx, y: 0, width, height });
					}
					return frames;
				}
			}

			class Scene {
				constructor() {
					this.lastTime = 0;
					this.elapsedTime = 0;
					this.element = document.createElement("canvas");
					this.context = this.element.getContext("2d");
					this.size = { width: 1, height: 1 };
				}

				main() {
					const now = Date.now();
					const dt = (now - this.lastTime) / 1000.0;

					this.update(dt);
					this.render();
					this.lastTime = now;

					requestAnimationFrame(this.main.bind(this));
				}

				update() {}

				render() {}

				sizeDidChange() {}

				get size() {
					return { width: this._size.width, height: this._size.height };
				}

				set size(size) {
					const element = this.element;
					const scale = 0.5;

					element.width = size.width * scale;
					element.height = size.height * scale;
					element.style.width = `${size.width}px`;
					element.style.height = `${size.height}px`;

					this.context.setTransform(scale, 0, 0, scale, 0, 0);

					this._size = { width: size.width, height: size.height };
					this.sizeDidChange(this._size);
				}
			}

			const Random = {
				floatValue(min, max) {
					return Math.random() * (max - min) + min;
				},
				integerValue(min, max) {
					return Math.floor(Math.random() * (max - min + 1)) + min;
				},
				color() {
					return `#${Math.floor(Math.random() * 16777215).toString(16)}`;
				}
			};

			CanvasRenderingContext2D.prototype.roundedRect = function (x, y, w, h, r) {
				if (w < 2 * r) r = w / 2;
				if (h < 2 * r) r = h / 2;
				this.beginPath();
				this.moveTo(x + r, y);
				this.arcTo(x + w, y, x + w, y + h, r);
				this.arcTo(x + w, y + h, x, y + h, r);
				this.arcTo(x, y + h, x, y, r);
				this.arcTo(x, y, x + w, y, r);
				this.closePath();
				return this;
			};

			function createSpriteSheet() {
				const frames = 4;
				const frameWidth = 240;
				const frameHeight = 72;
				const sheet = document.createElement("canvas");
				sheet.width = frameWidth * frames;
				sheet.height = frameHeight;

				const ctx = sheet.getContext("2d");
				ctx.imageSmoothingEnabled = false;
				ctx.textAlign = "center";
				ctx.textBaseline = "middle";

				const colors = ["#ffd6ff", "#bde0fe", "#caffbf", "#fff3b0"];
				for (let i = 0; i < frames; i += 1) {
					const x = frameWidth * i;
					const y = 0;
					const wobble = i % 2 === 0 ? 0 : 2;

					ctx.fillStyle = "rgba(0, 0, 0, 0.25)";
					ctx.fillRect(x + 10, y + 10, frameWidth - 20, frameHeight - 20);

					ctx.fillStyle = colors[i];
					ctx.font = "bold 18px ui-monospace, SFMono-Regular, Menlo, monospace";
					ctx.fillText("Happy", x + frameWidth / 2, frameHeight / 2 - 8 + wobble);
					ctx.fillText("Birthday", x + frameWidth / 2, frameHeight / 2 + 12 + wobble);

					for (let dot = 0; dot < 12; dot += 1) {
						ctx.fillStyle = colors[(i + dot) % colors.length];
						const dx = x + Random.integerValue(8, frameWidth - 8);
						const dy = Random.integerValue(6, frameHeight - 6);
						ctx.fillRect(dx, dy, 2, 2);
					}
				}

				const image = new Image();
				image.src = sheet.toDataURL("image/png");

				return { image, frameWidth, frameHeight, frames };
			}

			function loadImage(src) {
				return new Promise((resolve, reject) => {
					const img = new Image();
					img.onload = () => resolve(img);
					img.onerror = () => reject(new Error(`Failed to load ${src}`));
					img.src = src;
				});
			}

			class BirthdayScene extends Scene {
				constructor() {
					super();

					this.backgroundColor = "#000";
					this.containerColor = "#000";
					this.entities = [];

					const { image, frameWidth, frameHeight, frames } = createSpriteSheet();
					const messageReady = new Promise((resolve) => {
						image.onload = () => resolve(image);
					});

					const photo1Src = `${BASE_URL}assets/firas-birthday/firas-1.jpg`;
					const photo2Src = `${BASE_URL}assets/firas-birthday/firas-2.jpg`;

					Promise.all([messageReady, loadImage(photo1Src), loadImage(photo2Src)])
						.then(([messageImage, photo1, photo2]) => {
							const messageSprite = new Sprite(
								messageImage,
								Sprite.GeometryHorizontalLinear(frameWidth, frameHeight, frames)
							);
							const photoSprite1 = new Sprite(photo1, [
								{ x: 0, y: 0, width: photo1.width, height: photo1.height }
							]);
							const photoSprite2 = new Sprite(photo2, [
								{ x: 0, y: 0, width: photo2.width, height: photo2.height }
							]);

							this.sprites = {
								message: messageSprite,
								photo1: photoSprite1,
								photo2: photoSprite2
							};
							this.main();
						})
						.catch(() => {
							const messageSprite = new Sprite(
								image,
								Sprite.GeometryHorizontalLinear(frameWidth, frameHeight, frames)
							);
							this.sprites = { message: messageSprite };
							this.main();
						});
				}

				sizeDidChange() {
					this.context.imageSmoothingEnabled = false;
				}

				pickSpriteKey() {
					if (!this.sprites?.photo1 || !this.sprites?.photo2) {
						return "message";
					}
					const roll = Math.random();
					if (roll < 0.15) return "photo1";
					if (roll < 0.3) return "photo2";
					return "message";
				}

				createEntity(spriteKey = this.pickSpriteKey()) {
					const sprite = this.sprites[spriteKey];
					const firstFrame = sprite.frames[0];

					const direction = Random.integerValue(0, 1);
					const opacity = Random.floatValue(0.2, 1.0);
					const translationX = Random.integerValue(240, 900) * (direction ? 1 : -1);

					const containerWidth = this.size.width;
					const containerHeight = this.size.height;
					const intrinsicSize = { width: firstFrame.width, height: firstFrame.height };

					const isPhoto = spriteKey.startsWith("photo");
					const minWidth = isPhoto ? 140 : 160;
					const maxWidth = isPhoto ? Math.min(320, containerWidth * 0.4) : Math.min(420, containerWidth * 0.55);
					const targetWidth = Random.integerValue(minWidth, Math.max(minWidth, maxWidth));
					const scale = targetWidth / intrinsicSize.width;

					const size = {
						width: intrinsicSize.width * scale,
						height: intrinsicSize.height * scale
					};
					const origin = {
						x: direction ? -size.width : containerWidth,
						y: Random.integerValue(0, Math.max(0, containerHeight - size.height))
					};

					return {
						sprite,
						animationFrameDuration: isPhoto ? 0.2 : 0.09,
						animationFrame: 0,
						time: 0.0,
						speed: { x: translationX, y: 0 },
						size,
						origin,
						opacity,
						intrinsicSize
					};
				}

				render() {
					const context = this.context;
					const { width, height } = this.size;

					context.globalAlpha = 1;
					context.fillStyle = this.backgroundColor;
					context.fillRect(0, 0, width, height);

					const padding = 32;
					const radius = 12;

					if (width > radius * 2 && height > radius * 2) {
						context.roundedRect(padding, padding, width - 2 * padding, height - 2 * padding, radius);
						context.fillStyle = this.containerColor;
						context.fill();
					}

					for (const entity of this.entities) {
						const { sprite, animationFrame, origin, size, opacity } = entity;
						context.globalAlpha = opacity;
						sprite.drawFrame(context, animationFrame, origin.x, origin.y, size.width, size.height);
					}
				}

				update(dt) {
					this.elapsedTime += dt;
					if (this.elapsedTime >= 0.35) {
						this.elapsedTime = 0;
						this.backgroundColor = Random.color();
						this.containerColor = Random.color();

						let add = 2;
						while (add--) {
							this.entities.push(this.createEntity());
						}
					}

					const containerWidth = this.size.width;
					const containerHeight = this.size.height;

					let protagonist = this.protagonist;
					if (!protagonist) {
						protagonist = this.createEntity("message");
						protagonist.speed.x = 0;
						protagonist.opacity = 1;
						this.entities.push(protagonist);
						this.protagonist = protagonist;
					}

					if (protagonist) {
						const maxSize = {
							width: Math.min(containerWidth * 0.8, 600),
							height: Math.min(containerHeight * 0.8, 600)
						};
						const size = protagonist.intrinsicSize;
						const xScale = maxSize.width / size.width;
						const yScale = maxSize.height / size.height;
						const minScale = Math.min(xScale, yScale);
						const scaledSize = { width: size.width * minScale, height: size.height * minScale };

						protagonist.size = scaledSize;
						protagonist.origin.x = Math.round((containerWidth - scaledSize.width) * 0.5);
						protagonist.origin.y = Math.round((containerHeight - scaledSize.height) * 0.5);
					}

					const offscreenIndexes = [];
					let idx = 0;
					for (const entity of this.entities) {
						entity.time += dt;
						if (entity.time >= entity.animationFrameDuration) {
							const nextFrame = entity.animationFrame + 1;
							entity.time = 0;
							entity.animationFrame =
								nextFrame < entity.sprite.frames.length ? nextFrame : 0;
						}

						if (entity.speed.x !== 0) {
							entity.origin.x += (entity.speed.x * dt) | 0;
						}

						if (entity.origin.x > containerWidth || entity.origin.x <= -entity.size.width) {
							offscreenIndexes.push(idx);
						}

						idx += 1;
					}

					for (const removeIndex of offscreenIndexes.reverse()) {
						this.entities.splice(removeIndex, 1);
					}
				}
			}

			class MainController {
				constructor(container) {
					this.container = container;

					const scene = new BirthdayScene();
					scene.element.style.display = "none";
					container.appendChild(scene.element);

					window.addEventListener("resize", this.handleResize.bind(this));
					this.scene = scene;
					this.handleResize();

					const loadingElement = document.createElement("span");
					loadingElement.textContent = "Preparing...";

					const audioPlayer = document.getElementById("party-audio");

					const showScene = () => {
						if (loadingElement.parentNode) {
							loadingElement.parentNode.removeChild(loadingElement);
						}
						scene.element.classList.add("cue-in");
						scene.element.style.display = "block";
						document.title = "Firas Birthday";
					};

					if (audioPlayer) {
						audioPlayer.addEventListener("play", showScene);
					} else {
						showScene();
					}

					const button = document.createElement("button");
					button.textContent = "SURPRISE ME";
					button.addEventListener("click", async () => {
						button.parentNode.removeChild(button);
						container.appendChild(loadingElement);

						if (!audioPlayer) {
							showScene();
							return;
						}

						try {
							await audioPlayer.play();
						} catch (error) {
							showScene();
						}
					});

					container.appendChild(button);
				}

				handleResize() {
					this.scene.size = {
						width: Math.floor(window.innerWidth),
						height: Math.floor(window.innerHeight)
					};
				}
			}

			function awake() {
				window.controller = new MainController(document.body);
			}

			document.addEventListener("DOMContentLoaded", awake);
		</script>
	</body>
</html>
